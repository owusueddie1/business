# Database connection string for Prisma/PostgreSQL
# Replace with your Supabase database URL from the Supabase project settings.
DATABASE_URL="postgresql://user:password@localhost:5432/dbname"

# Public Supabase project URL used in client-side code.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"

# Public anonymous key for Supabase client auth.
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-public-anon-key"

# Supabase service role key used on the server for privileged operations.
# Get this from Supabase > Settings > API > Service Role Key.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Gemini API key for OpenAI/Google Gemini integration.
# Store the key from your Gemini API provider console.
GEMINI_API_KEY="your-gemini-api-key"

# GROQ API key for Sanity or other GROQ-compatible APIs.
# Get this from your CMS provider's API settings.
GROQ_API_KEY="your-groq-api-key"

# Anthropic API key for Claude or other Anthropic services.
# Obtain this from your Anthropic account dashboard.
ANTHROPIC_API_KEY="your-anthropic-api-key"

# NextAuth secret for signing cookies and tokens.
# Generate a strong secret using openssl or a secrets manager.
NEXTAUTH_SECRET="your-nextauth-secret"

# Base URL for your application, used by NextAuth callbacks.
NEXTAUTH_URL="http://localhost:3000"
